{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "latexEntry",
      "type": "promptString",
      "description": "Entry .tex path (relative to workspace)",
      "default": "manuscript/main.tex"
    }
  ],
  "tasks": [
    {
      "label": "LaTeX: Quick compile (choose entry)",
      "type": "shell",
      "command": "bash ./scripts/compile-thesis.sh quick ${input:latexEntry}",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$latex",
      "presentation": {
        "reveal": "silent",
        "focus": false,
        "echo": true
      }
    },
    {
      "label": "LaTeX: Full compile (choose entry)",
      "type": "shell",
      "command": "bash ./scripts/compile-thesis.sh full ${input:latexEntry}",
      "group": {
        "kind": "build"
      },
      "problemMatcher": "$latex",
      "presentation": {
        "reveal": "silent",
        "focus": true
      }
    },
    {
      "label": "LaTeX: Clean manuscript artifacts",
      "type": "shell",
      "command": "bash ./scripts/compile-thesis.sh clean",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "LaTeX: View compiled PDF (from entry)",
      "type": "shell",
      "command": "bash -lc 'entry=\"${input:latexEntry}\"; pdf=\"${entry%.tex}.pdf\"; open \"$pdf\" 2>/dev/null || xdg-open \"$pdf\"'",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
